{
  "name": "frontend",
  "version": "0.6.2",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "check": "run-s check:harness check:links check:api check:agent-rules check:eslint-baseline type-check build-only",
    "check:harness": "bun run scripts/check-harness-docs.ts",
    "check:links": "bun run scripts/check-markdown-links.ts",
    "check:api": "bun run scripts/generate-openapi-summary.ts --check",
    "check:agent-rules": "bun run scripts/check-agent-rules.ts",
    "check:eslint-baseline": "bun run scripts/check-eslint-baseline.ts",
    "generate:api-summary": "bun run scripts/generate-openapi-summary.ts",
    "generate:eslint-baseline": "bun run scripts/check-eslint-baseline.ts --update",
    "diff:distribution": "bun run scripts/diff-distribution.ts",
    "lint": "bun run lint:fix",
    "lint:check": "bun run check:eslint-baseline",
    "lint:fix": "eslint . --fix --cache",
    "format": "prettier --write src/ scripts/ docs/ AGENTS.md ARCHITECTURE.md SKILL.md",
    "format:check": "prettier --check src/ scripts/ docs/ AGENTS.md ARCHITECTURE.md SKILL.md",
    "release": "bun run scripts/release.ts"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "chartjs-plugin-annotation": "^3.1.0",
    "heatmap.js": "^2.0.5",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.33",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@tsconfig/node22": "^22.0.5",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "~10.9.0",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.8.3",
    "prettier-plugin-vue": "^1.1.6",
    "stylelint": "^17.9.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.7"
  }
}
